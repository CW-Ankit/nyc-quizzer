# NYC Quizzer Bot - Environment Variables

# Discord Bot Token
DISCORD_TOKEN=your_discord_bot_token_here

# Client ID
CLIENT_ID=your_client_id_here

# Access Control
NOT_YOUR_PAL_ROLE_ID=your_role_id_here
ALLOWED_QUIZ_CHANNELS=channel_id_1,channel_id_2

# AI Generation (OpenRouter)
OPENROUTER_API_KEY=your_api_key_here
OPENROUTER_MODEL=google/gemini-flash-1.5-exp

# Broadcast Settings
BROADCAST_CHANNEL_ID=your_channel_id_here
DROP_INTERVAL=*/30 * * * *
